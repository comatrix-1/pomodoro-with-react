{
  "name": "pomodoro2",
  "version": "0.1.0",
  "homepage": ".",
  "private": true,
  "type": "module",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "serve:dist": "http-server dist -p 8080 -c-1 --silent",
    "test:e2e": "start-server-and-test serve:dist http://localhost:8080 \"cypress run\"",
    "test:e2e:open": "start-server-and-test serve:dist http://localhost:8080 \"cypress open\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.44.0",
    "@typescript-eslint/parser": "^5.44.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cypress": "^15.17.0",
    "eslint": "^8.28.0",
    "gh-pages": "^3.2.3",
    "http-server": "^14.1.1",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.5.0",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
